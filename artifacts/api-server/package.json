{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "ingest:media": "tsx src/scripts/ingest-media-mentions.ts",
    "sync:flodesk": "tsx src/scripts/sync-flodesk.ts",
    "sync:schools": "tsx src/scripts/sync-schools.ts",
    "sync:donorbox": "tsx src/scripts/sync-donorbox.ts",
    "resync:quickbooks": "tsx src/scripts/resync-quickbooks.ts",
    "backfill:flodesk": "tsx src/scripts/backfill-flodesk.ts",
    "backfill:derived-opps": "tsx src/scripts/backfill-derived-opp-fields.ts",
    "backfill:gift-qb-tie": "tsx src/scripts/backfill-gift-qb-tie.ts",
    "parity:payment-applications": "tsx src/scripts/parity-payment-applications.ts",
    "parity:reconciliation-guards": "tsx src/scripts/parity-reconciliation-guards.ts",
    "parity:loan-or-grant": "tsx src/scripts/parity-loan-or-grant.ts",
    "backfill:funding-source": "tsx src/scripts/backfill-funding-source.ts",
    "reconcile:unknown-users": "tsx src/scripts/reconcile-unknown-users.ts",
    "backfill:user-identities": "tsx src/scripts/backfill-user-identities.ts",
    "backfill:sync-suppression": "tsx src/scripts/backfill-sync-suppression.ts",
    "backfill:email-domains": "tsx src/scripts/backfill-email-domains.ts",
    "backfill:task-suggestions": "tsx src/scripts/backfill-task-suggestions.ts",
    "refresh:task-suggestions": "tsx src/scripts/refresh-task-suggestions.ts",
    "migrate:organizations": "tsx src/scripts/migrate-organizations.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.1.4",
    "@google-cloud/storage": "^7.19.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^3.0.5",
    "nanoid": "^5.1.9",
    "p-limit": "^7.3.0",
    "pino": "^9",
    "pino-http": "^10",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.7"
  }
}
