modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["airtable:1.0.0", "stripe:1.0.0", "google-drive:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
COPPER_USER_EMAIL = "matthew.kramer@wildflowerschools.org"
FLODESK_SEGMENT_ID = "6a21f3ece6615f531081c6b2"
DONORBOX_USER_EMAIL = "erica.cantoni@wildflowerschools.org"

[userenv.development]
