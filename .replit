modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["airtable:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 21297
externalPort = 3000

[[ports]]
localPort = 21298
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
COPPER_USER_EMAIL = "matthew.kramer@wildflowerschools.org"
FLODESK_SEGMENT_ID = "6a21f3ece6615f531081c6b2"

[userenv.development]
