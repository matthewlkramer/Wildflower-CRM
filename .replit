modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "libs"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "codegen"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-api"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "full"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "libs"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck:libs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/wildflower-crm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "codegen"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-spec run codegen:check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-api"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/wildflower-crm run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "full"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["airtable:1.0.0", "stripe:1.0.0", "google-drive:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
COPPER_USER_EMAIL = "matthew.kramer@wildflowerschools.org"
FLODESK_SEGMENT_ID = "6a21f3ece6615f531081c6b2"
DONORBOX_USER_EMAIL = "erica.cantoni@wildflowerschools.org"

[userenv.development]

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 21297
externalPort = 3000

[[ports]]
localPort = 21298
externalPort = 3001

[[ports]]
localPort = 21299
externalPort = 3003

[objectStorage]
defaultBucketID = "replit-objstore-39859aa0-20a0-4a4b-a91b-acf1a7d6a730"
